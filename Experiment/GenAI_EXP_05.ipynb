# Imports
import re
import time
import pandas as pd
import matplotlib.pyplot as plt

from datasets import load_dataset
from transformers import pipeline
from google import genai
from getpass import getpass

# ==========================================================
# ENTER GEMINI API KEY
# ==========================================================
api_key = getpass("Enter Gemini API Key: ")

client = genai.Client(api_key=api_key)

# ==========================================================
# LOAD DATASET (2 QUESTIONS)
# ==========================================================
data = load_dataset("gsm8k", "main")["test"].select(range(2))

# ==========================================================
# LOAD HUGGINGFACE MODEL
# ==========================================================
hf = pipeline(
    "text-generation",
    model="distilgpt2"
)

# ==========================================================
# PROMPTING METHODS
# ==========================================================
def zero(q):
    return f"Q: {q}\nA:"

def few(q):
    return f"""
Q: 2 + 3 ?
A: 5

Q: 10 - 4 ?
A: 6

Q: {q}
A:
"""

def cot(q):
    return f"""
Solve step by step.

Q: {q}
A:
"""

# ==========================================================
# QUERY FUNCTIONS
# ==========================================================
def ask_hf(prompt):
    try:
        out = hf(
            prompt,
            max_new_tokens=40,
            do_sample=False,
            pad_token_id=50256
        )[0]["generated_text"]
        return out
    except:
        return "HF Error"

def ask_gemini(prompt):
    try:
        response = client.models.generate_content(
            model="gemini-2.5-flash",
            contents=prompt + "\nReturn only the final numeric answer."
        )
        return response.text.strip()
    except Exception as e:
        return "Quota exceeded / Error"

# ==========================================================
# NUMBER EXTRACTION
# ==========================================================
def get_num(text):
    nums = re.findall(r"-?\d+\.?\d*", str(text).replace(",", ""))
    return nums[-1] if nums else None

def get_gold(x):
    m = re.search(r"####\s*(-?\d+\.?\d*)", x.replace(",", ""))
    return m.group(1) if m else get_num(x)

# ==========================================================
# RESULT CHECK
# ==========================================================
def check(pred, gold):
    if pred is None:
        return "Hallucination"
    elif pred == gold:
        return "Correct"
    else:
        return "Wrong"

# ==========================================================
# RUN TEST
# ==========================================================
results = []

for row in data:

    question = row["question"]
    gold = get_gold(row["answer"])

    for name, fn in [
        ("Zero-shot", zero),
        ("Few-shot", few),
        ("CoT", cot)
    ]:

        prompt = fn(question)

        hf_out = ask_hf(prompt)
        gem_out = ask_gemini(prompt)

        hf_pred = get_num(hf_out)
        gem_pred = get_num(gem_out)

        results.append([
            name,
            question[:60],
            gold,
            hf_pred,
            gem_pred,
            check(hf_pred, gold),
            check(gem_pred, gold)
        ])

        time.sleep(3)


df = pd.DataFrame(results, columns=[
    "Prompt",
    "Question",
    "Gold",
    "HF_Pred",
    "Gemini_Pred",
    "HF_Result",
    "Gemini_Result"
])

print("FULL RESULTS TABLE")
print(df)


acc = pd.DataFrame({
    "HF Accuracy %":
        df["HF_Result"].eq("Correct").groupby(df["Prompt"]).mean() * 100,

    "Gemini Accuracy %":
        df["Gemini_Result"].eq("Correct").groupby(df["Prompt"]).mean() * 100
})

print("\nACCURACY TABLE")
print(acc)

# ==========================================================
# GRAPH
# ==========================================================
acc.plot(kind="bar", figsize=(8,5))

plt.title("Prompting Technique Comparison")
plt.xlabel("Prompt Type")
plt.ylabel("Accuracy %")
plt.xticks(rotation=0)
plt.grid(True)
plt.show()

# ==========================================================
# SUMMARY
# ==========================================================
print("\nHF SUMMARY")
print(df["HF_Result"].value_counts())

print("\nGEMINI SUMMARY")
print(df["Gemini_Result"].value_counts())
